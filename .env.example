# TEHTEK ERP Backend — Example Environment File
# Safe to commit. Do not put real secrets here.

DATABASE_URL=postgresql://USER:PASSWORD@db:5432/DATABASE_NAME

SECRET_KEY=replace_with_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
RESET_TOKEN_EXPIRE_MINUTES=30

APP_NAME="TEHTEK ERP API"
APP_VERSION="2.0.0"
APP_ENV=production
DEBUG=false

MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

ALLOWED_ORIGINS='["https://app.example.com","https://customer.example.com"]'

SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PHONE=+237600000000
SUPERADMIN_PASSWORD=replace_with_strong_password
SUPERADMIN_FIRST_NAME=Admin
SUPERADMIN_LAST_NAME=User